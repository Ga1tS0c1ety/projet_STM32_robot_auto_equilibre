# ==========================================================
# STM32 Project - Global .gitignore
# ==========================================================

# -------------------------
# Build directories
# -------------------------
build/
*/build/
**/build/

# -------------------------
# CMake generated files
# -------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
build.ninja
.ninja_deps
.ninja_log
compile_commands.json

# -------------------------
# Binary files
# -------------------------
*.elf
*.bin
*.hex
*.map
*.o
*.obj
*.a
*.d
*.su
*.lst

# -------------------------
# Debug files
# -------------------------
*.log

# -------------------------
# VS Code
# -------------------------
.vscode/

# -------------------------
# Eclipse / CubeIDE
# (on garde les fichiers nécessaires au projet)
# -------------------------
.settings/

# -------------------------
# OS files
# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# Temporary files
# -------------------------
*~
*.swp
*.swo

# -------------------------
# caches de latex
# -------------------------

*.aux
*.aut
*.out
*.toc
*.synctex.gz
